# ============================================================
# EduPayNG NestJS Backend – Environment Variables
# ============================================================

# Server
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Remita Payment
REMITA_API_KEY=your-remita-api-key
REMITA_MERCHANT_ID=your-merchant-id
REMITA_SERVICE_TYPE_ID=your-service-type-id
REMITA_BASE_URL=https://api.remita.net
REMITA_WEBHOOK_SECRET=your-webhook-secret

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# SendGrid
SENDGRID_API_KEY=SG.your-key
SENDGRID_FROM_EMAIL=noreply@edupayng.com
SENDGRID_FROM_NAME=EduPayNG

# Termii SMS
TERMII_API_KEY=your-termii-key
TERMII_SENDER_ID=EduPay

# Throttle (rate limiting)
THROTTLE_TTL=60
THROTTLE_LIMIT=100
